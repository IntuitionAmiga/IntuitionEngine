-- Intuition Engine Product Demo Script
-- Fully automated showcase covering all 6 CPUs, 6 video chips, 20 audio formats,
-- machine monitor, Lua scripting, EhBASIC, Voodoo 3D, copper coprocessor, retro chips.
-- Records to MP4 with screen-capture mode (overlays visible in video).

-- ============================================================================
-- Setup: Paths and Constants
-- ============================================================================

local BASIC        = "sdk/examples/prebuilt/ehbasic_ie64.ie64"
local P            = "sdk/examples/prebuilt/"
local M            = "sdk/examples/assets/music/"

-- ============================================================================
-- Preflight Check: Verify all music files exist
-- ============================================================================

local MUSIC_FILES = {
    M.."demo_sid.sid", M.."demo_pokey.sap", M.."demo_ted.ted",
    M.."demo_sndh.sndh", M.."demo_sn76489.vgm", M.."demo_sn76489.vgz",
    M.."demo_ay_spectrum.ay", M.."demo_ay_cpc.ay",
    M.."demo_ym.ym", M.."demo_vtx.vtx",
    M.."demo_pt3.pt3", M.."demo_pt2.pt2", M.."demo_pt1.pt1",
    M.."demo_stc.stc", M.."demo_sqt.sqt", M.."demo_asc.asc",
    M.."demo_ftc.ftc", M.."demo_ahx.ahx", M.."demo_mod.mod",
    M.."demo_wav.wav",
}

local missing = {}
for _, path in ipairs(MUSIC_FILES) do
    local f = io.open(path, "r")
    if f then f:close() else missing[#missing+1] = path end
end

if #missing > 0 then
    sys.print("ERROR: Demo music files missing:")
    for _, p in ipairs(missing) do sys.print("  " .. p) end
    sys.exit(1)
end

-- ============================================================================
-- Helper Functions
-- ============================================================================

-- Type character-by-character into BASIC terminal
local function slow_type(s, ms)
    ms = ms or 55
    for i = 1, #s do term.type(s:sub(i,i)); sys.wait_ms(ms) end
end

-- Wait for BASIC "Ready" prompt; raises error on timeout
local function wait_ready(ms)
    assert(term.wait_output("Ready", ms or 5000),
        "BASIC not ready within " .. tostring(ms or 5000) .. "ms")
end

-- Switch back to EhBASIC and wait for prompt
local function reset_to_basic()
    media.stop()
    term.read() -- drain stale output before reload
    cpu.load(BASIC)
    sys.wait_ms(1500)
    wait_ready(8000)
    sys.wait_ms(300)
end

-- Show REPL overlay title card and wait
local function title_card(lines, hold_s)
    hold_s = hold_s or 3
    repl.show(); repl.clear()
    repl.print("  ================================================")
    for _, l in ipairs(lines) do repl.print("  " .. l) end
    repl.print("  ================================================")
    sys.wait_ms(hold_s * 1000)
    repl.hide()
end

-- Print many lines to REPL then slowly scroll through them
local function repl_scroll(lines, delay_ms)
    delay_ms = delay_ms or 200
    repl.show(); repl.clear()
    for _, l in ipairs(lines) do repl.print(l); sys.wait_ms(30) end
    repl.scroll_up(repl.line_count())
    for _ = 1, repl.line_count() do sys.wait_ms(delay_ms); repl.scroll_down(1) end
    sys.wait_ms(400); repl.hide()
end

-- Load and run a demo binary, wait N seconds
local function run_demo(path, secs)
    media.stop(); audio.reset()
    cpu.load(path)
    sys.wait_ms(600); sys.wait_frames(30)
    if secs and secs > 0 then sys.wait_ms(secs * 1000) end
end

-- Open monitor, run commands with pauses, close
local function monitor_tour(cmds)
    dbg.open(); sys.wait_ms(500)
    for _, e in ipairs(cmds) do
        dbg.command(e[1]); sys.wait_ms(e[2] or 1800)
    end
    dbg.close(); sys.wait_ms(400)
end

-- Play a music file via BASIC SOUND PLAY command
local function play_music(path, hold_ms)
    hold_ms = hold_ms or 8000
    term.read() -- drain stale output
    slow_type('SOUND PLAY "'..path..'"', 55)
    term.type("\n"); sys.wait_ms(hold_ms)
    term.read() -- drain before waiting for Ready
    slow_type("SOUND PLAY STOP", 55)
    term.type("\n"); wait_ready(2000)
end

-- Get metadata string for current song (returns title + author if available)
local function get_song_info(meta_type)
    local meta
    if meta_type == "psg" then
        meta = audio.psg_metadata()
    elseif meta_type == "sid" then
        meta = audio.sid_metadata()
    end
    if meta and meta.title and meta.title ~= "" then
        local info = meta.title
        if meta.author and meta.author ~= "" then
            info = info .. " - " .. meta.author
        end
        return info
    end
    return nil
end

-- Play music with metadata title card shown after song starts
local function play_music_with_info(path, chip_label, hold_ms, meta_type, num, total)
    hold_ms = hold_ms or 8000
    total = total or 20
    term.read()
    slow_type('SOUND PLAY "'..path..'"', 55)
    term.type("\n"); sys.wait_ms(1500)
    -- Query metadata after song has loaded and is audible
    local song_info = get_song_info(meta_type)
    local lines = {string.format("[%d/%d] %s", num, total, chip_label)}
    if song_info then lines[#lines+1] = song_info end
    title_card(lines, 4)
    sys.wait_ms(hold_ms - 5500)
    term.read()
    slow_type("SOUND PLAY STOP", 55)
    term.type("\n"); wait_ready(2000)
end

