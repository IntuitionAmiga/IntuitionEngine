    "-- This product demo is 100% automated",
    "-- driven by a single Lua script (this one).",
    "-- No user interaction required.",
    "",
    "-- Features demonstrated:",
    "  . 6 CPUs (IE32, IE64, M68K, 6502, Z80, x86)",
    "  . 6 Video chips (VideoChip, VGA, ULA, TED, ANTIC, Voodoo 3D)",
    "  . 20 Audio formats (SID, SAP, AHX, TED, AY, YM, VGM, MOD, WAV...)",
    "  . Machine monitor debugger with live register view",
    "  . EhBASIC interpreter with BLIT graphics",
    "  . Copper coprocessor and DMA blitter and SNES Mode7 affine texture unit",
    "",
    "-- Lua API provides programmatic control:",
    "  cpu.load(path)    -- Load and execute program",
    "  sys.wait_ms(n)    -- Wait N milliseconds",
    "  rec.start_screen(path)  -- Screen-capture recording",
    "  dbg.open/close()  -- Machine monitor control",
    "  repl.show/hide()  -- REPL overlay visibility",
}
repl_scroll(script_lines, 150)

-- ============================================================================
-- Section 2: BASIC Rotozoomer - First Demo! (35s)
-- ============================================================================

title_card({
    "EhBASIC Rotozoomer",
    "CPU: IE64 running EhBASIC interpreter",
    "Video: VideoChip 640x480 + Mode7 hardware blitter",
    "Audio: SID (MOS 6581/8580)",
}, 3)

-- Load the BASIC source code into REPL overlay and scroll through it
local bas_file = io.open("sdk/examples/basic/rotozoomer_basic.bas", "r")
if bas_file then
    repl.show(); repl.clear()
    repl.print("  === BASIC Source: rotozoomer_basic.bas ===")
    repl.print("")
    for line in bas_file:lines() do repl.print(line) end
    bas_file:close()
    -- Scroll to top then slowly scroll down through the listing
    local total_lines = repl.line_count()
    repl.scroll_up(total_lines)
    sys.wait_ms(1000)
    for _ = 1, total_lines do
        repl.scroll_down(1)
        sys.wait_ms(60)
    end
    sys.wait_ms(1500)
    repl.hide()
end

-- Load and run the BASIC program
slow_type('LOAD "sdk/examples/basic/rotozoomer_basic.bas"', 45)
term.type("\n"); wait_ready(5000)
sys.wait_ms(500)
slow_type("RUN", 45)
term.type("\n")
sys.wait_ms(15000) -- watch the rotozoomer with SID music

