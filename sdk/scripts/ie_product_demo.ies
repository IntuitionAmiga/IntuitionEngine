    {M.."demo_pokey.sap",   "POKEY — Atari 8-bit"},
    {M.."demo_ted.ted",     "TED — Commodore Plus/4"},
    {M.."demo_sndh.sndh",   "YM2149 — Atari ST (also .snd)"},
}

for i, e in ipairs(music_groups_a) do
    title_card({string.format("[%d/19] %s", i, e[2])}, 1)
    slow_type('SOUND PLAY "'..e[1]..'"', 55)
    term.type("\n"); sys.wait_ms(8000)
    slow_type("SOUND PLAY STOP", 55)
    term.type("\n"); wait_ready(2000)
end

