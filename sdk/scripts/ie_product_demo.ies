-- ============================================================================
-- Section 11: Monitor Deep-Dive (30s)
-- ============================================================================

reset_to_basic()
title_card({"Machine Monitor Deep-Dive", "Live register & memory inspection"}, 2)

slow_type("10 FOR I=1 TO 100: POKE &HF0800, I*2: NEXT I", 45)
term.type("\n"); sys.wait_ms(300)
slow_type("RUN", 45)
term.type("\n"); wait_ready(1500)
sys.wait_ms(3000)

monitor_tour({
    {"r",        2500},
    {"d",        2200},
    {"d 0x1000", 2000},
    {"m 0",      2000},
    {"m 0x1000", 1800},
    {"io",       2200},
    {"bt",       2000},
    {"bl",       1500},
    {"trace 8",  3000},
})

-- ============================================================================
-- Section 12: BASIC Live Coding (22s)
-- ============================================================================

reset_to_basic()
title_card({"BASIC Live Coding", "Rotozoomer Algorithm"}, 2)

local code_lines = {
    {"POKE &HF0000, 1",                                       400},
    {"W=640: H=480: ANG=0",                                   300},
    {"10 ANG=ANG+0.05",                                       300},
    {"20 S=SIN(ANG)*64: C=COS(ANG)*64",                       300},
    {"30 FOR Y=0 TO H-1 STEP 8",                              300},
    {"40 FOR X=0 TO W-1 STEP 8",                              300},
    {"50 COL=(INT((X*C-Y*S)/64) XOR INT((X*S+Y*C)/64)) AND 1",300},
    {"60 BLIT FILL &H100000+((Y*W+X)*4),32,COL*&HFFFFFFFF",   300},
    {"70 NEXT X: NEXT Y",                                     300},
    {"80 WAIT &HF0008, 2: GOTO 10",                           300},
    {"RUN",                                                   300},
}

for _, e in ipairs(code_lines) do
    slow_type(e[1], 45)
    term.type("\n")
    sys.wait_ms(e[2])
end
sys.wait_ms(12000)

-- ============================================================================
