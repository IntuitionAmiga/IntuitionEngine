-- Intuition Engine Product Demo Script (~480 lines)
-- Fully automated showcase covering all 6 CPUs, 6 video chips, 19 audio formats,
-- machine monitor, Lua scripting, EhBASIC, Voodoo 3D, copper coprocessor, retro chips.
-- Records to MP4 with screen-capture mode (overlays visible in video).

-- ============================================================================
-- Setup: Paths and Constants
-- ============================================================================

local BASIC        = "sdk/examples/prebuilt/ehbasic_ie64.ie64"
local P            = "sdk/examples/prebuilt/"
local M            = "sdk/examples/assets/music/"
local A            = "sdk/examples/assets/"

-- ============================================================================
-- Preflight Check: Verify all music files exist
-- ============================================================================

local MUSIC_FILES = {
    M.."demo_sid.sid", M.."demo_pokey.sap", M.."demo_ted.ted",
    M.."demo_sndh.sndh", M.."demo_sn76489.vgm", M.."demo_sn76489.vgz",
    M.."demo_ay.ay", M.."demo_ym.ym", M.."demo_vtx.vtx",
    M.."demo_pt3.pt3", M.."demo_pt2.pt2", M.."demo_pt1.pt1",
    M.."demo_stc.stc", M.."demo_sqt.sqt", M.."demo_asc.asc",
    M.."demo_ftc.ftc", M.."demo_ahx.ahx", M.."demo_mod.mod",
    M.."demo_wav.wav",
}

local missing = {}
for _, path in ipairs(MUSIC_FILES) do
    local f = io.open(path, "r")
    if f then f:close() else missing[#missing+1] = path end
end

if #missing > 0 then
    sys.print("ERROR: Demo music files missing. Add to sdk/examples/assets/music/:")
    for _, p in ipairs(missing) do sys.print("  " .. p) end
    sys.print("See Section 3 of the plan for placeholder-to-track mapping.")
    sys.exit(1)
end

-- ============================================================================
-- Helper Functions
-- ============================================================================

-- Type character-by-character into BASIC terminal
local function slow_type(s, ms)
    ms = ms or 55
    for i = 1, #s do term.type(s:sub(i,i)); sys.wait_ms(ms) end
end

-- Wait for BASIC "Ready." prompt; raises error on timeout
local function wait_ready(ms)
    assert(term.wait_output("Ready.", ms or 5000),
        "BASIC not ready within " .. tostring(ms or 5000) .. "ms")
end

-- Switch back to EhBASIC and wait for prompt
local function reset_to_basic()
    media.stop()
    cpu.load(BASIC)
    sys.wait_ms(1500)
    wait_ready(8000)
    sys.wait_ms(300)
end

-- Show REPL overlay title card and wait
local function title_card(lines, hold_s)
    hold_s = hold_s or 3
    repl.show(); repl.clear()
    repl.print("  ================================================")
    for _, l in ipairs(lines) do repl.print("  " .. l) end
    repl.print("  ================================================")
    sys.wait_ms(hold_s * 1000)
    repl.hide()
end

-- Print many lines to REPL then slowly scroll through them
local function repl_scroll(lines, delay_ms)
    delay_ms = delay_ms or 200
    repl.show(); repl.clear()
    for _, l in ipairs(lines) do repl.print(l); sys.wait_ms(30) end
    repl.scroll_up(repl.line_count())
    for _ = 1, repl.line_count() do sys.wait_ms(delay_ms); repl.scroll_down(1) end
    sys.wait_ms(400); repl.hide()
end

-- Load and run a demo binary, wait N seconds
local function run_demo(path, secs)
    media.stop(); cpu.load(path)
    sys.wait_ms(600); sys.wait_frames(30)
    if secs and secs > 0 then sys.wait_ms(secs * 1000) end
end

-- Open monitor, run commands with pauses, close
local function monitor_tour(cmds)
    dbg.open(); sys.wait_ms(500)
    for _, e in ipairs(cmds) do
        dbg.command(e[1]); sys.wait_ms(e[2] or 1800)
    end
    dbg.close(); sys.wait_ms(400)
end

-- ============================================================================
-- Section 0: Opening - Start recording and title card
-- ============================================================================

rec.start_screen("ie_product_demo.mp4")
title_card({"Intuition Engine — Retro Emulator", "Automated Feature Showcase"}, 8)

-- ============================================================================
-- Section 1: Lua Scripting Meta (18s)
-- ============================================================================

title_card({"Lua Scripting Showcase", "This script narrates itself"}, 2)
local script_lines = {
    "-- This product demo is 100% automated",
    "-- driven by a single Lua script (this one).",
    "-- No user interaction required.",
    "",
    "-- Features demonstrated:",
    "  • 6 CPUs (IE32, IE64, M68K, 6502, Z80, x86)",
    "  • 6 Video chips (VideoChip, VGA, ULA, TED, ANTIC, Voodoo 3D)",
    "  • 19 Audio formats (SID, SAP, AHX, MOD, WAV, ZX trackers...)",
    "  • Machine monitor debugger with live register view",
    "  • EhBASIC interpreter with BLIT graphics",
    "  • Copper coprocessor and DMA blitter",
    "",
    "-- Lua API provides programmatic control:",
    "  cpu.load(path)    -- Load and execute program",
    "  sys.wait_ms(n)    -- Wait N milliseconds",
    "  rec.start_screen(path)  -- Screen-capture recording",
    "  dbg.open/close()  -- Machine monitor control",
    "  repl.show/hide()  -- REPL overlay visibility",
}
repl_scroll(script_lines, 150)

-- ============================================================================
-- Section 2: EhBASIC Showcase (30s)
-- ============================================================================

title_card({"EhBASIC Interpreter", "Live-coded on VideoChip"}, 2)
reset_to_basic()

local basic_commands = {
    {"? 2+2*3",                              400},
    {"? HEX$(65535)",                        400},
    {"? BIN$(15)",                           400},
    {"DIM A(4,4)",                           400},
    {"FOR I=0 TO 3:FOR J=0 TO 3:A(I,J)=I+J:NEXT:NEXT", 600},
    {"POKE &HF0000, 1",                      400},
    {"FOR I=0 TO 15: BLIT FILL &H100000+I*65536, 256, (I OR 128)*0x01010100 : NEXT", 800},
}

for _, e in ipairs(basic_commands) do
    slow_type(e[1], 45)
    term.type("\n")
    sys.wait_ms(e[2])
end
sys.wait_ms(2000)

-- ============================================================================
-- Section 3: Music Tour (19 distinct extensions, ~2m 30s)
